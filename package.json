{
  "name": "bizzi-cloud",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "migrate:organization-id": "DOTENV_CONFIG_PATH=.env.local npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r dotenv/config scripts/migrate-organization-id.ts",
    "migrate:org-files-to-workspaces": "DOTENV_CONFIG_PATH=.env.local npx ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/migrate-org-files-to-workspaces.ts",
    "migrate:org-shared-drives": "DOTENV_CONFIG_PATH=.env.local npx ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/migrate-org-shared-drives.ts",
    "orphan-cleanup": "DOTENV_CONFIG_PATH=.env.local npx ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/orphan-cleanup.ts",
    "set-user-password": "DOTENV_CONFIG_PATH=.env.local npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r dotenv/config scripts/set-user-password.ts",
    "sync-subscription": "DOTENV_CONFIG_PATH=.env.local npx ts-node -r ./scripts/register-paths.js --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/sync-subscription.ts",
    "delete-user-files": "DOTENV_CONFIG_PATH=.env.local npx ts-node -r ./scripts/register-paths.js --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/delete-user-files.ts",
    "reset-test-storage": "DOTENV_CONFIG_PATH=.env.local npx ts-node -r ./scripts/register-paths.js --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/reset-test-storage.ts",
    "backfill:backup-files-lifecycle": "DOTENV_CONFIG_PATH=.env.local npx ts-node -r ./scripts/register-paths.js --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/backfill-backup-files-lifecycle.ts",
    "backfill:linked-drives-folder-v2": "DOTENV_CONFIG_PATH=.env.local npx ts-node -r ./scripts/register-paths.js --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/backfill-linked-drives-folder-model-v2.ts",
    "mux:delete-all": "DOTENV_CONFIG_PATH=.env.local npx ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true}' -r dotenv/config scripts/delete-all-mux-assets.ts",
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/next/dist/bin/next lint",
    "b2:cors": "node scripts/set-b2-cors.mjs",
    "firebase:cors": "bash scripts/set-firebase-storage-cors.sh",
    "download:ffmpeg-braw": "node scripts/download-ffmpeg-braw.js",
    "worker:standard-proxy": "node scripts/standard-proxy-worker.mjs",
    "worker:braw-proxy": "node scripts/braw-proxy-worker.mjs",
    "k6:smoke": "./scripts/k6-with-env.sh run -e K6_EXECUTOR=constant-vus -e K6_VUS=5 -e K6_DURATION=45s k6/bizzi-api.js",
    "k6:ramp": "./scripts/k6-with-env.sh run k6/bizzi-api.js",
    "k6:arrival": "./scripts/k6-with-env.sh run -e K6_EXECUTOR=ramping-arrival-rate k6/bizzi-api.js",
    "k6:gallery": "./scripts/k6-with-env.sh run k6/gallery-public-traffic.js",
    "k6:notifications": "./scripts/k6-with-env.sh run k6/notifications-load.js",
    "k6:files": "./scripts/k6-with-env.sh run k6/files-browser-load.js",
    "k6:auth-abuse": "./scripts/k6-with-env.sh run k6/auth-abuse.js",
    "k6:proofing-abuse": "./scripts/k6-with-env.sh run k6/proofing-abuse.js",
    "k6:rate-limit": "./scripts/k6-with-env.sh run k6/rate-limit-verification.js",
    "k6:upload-storage": "./scripts/k6-with-env.sh run k6/upload-and-storage-load.js",
    "k6:mixed": "./scripts/k6-with-env.sh run k6/mixed-user-journey.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@emailjs/nodejs": "^5.0.2",
    "@napi-rs/canvas": "^0.1.88",
    "@uppy/aws-s3": "^5.1.0",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/react": "^5.2.0",
    "archiver": "^7.0.1",
    "exiftool-vendored": "^35.13.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "geist": "^1.3.1",
    "hash-wasm": "^4.12.0",
    "hls.js": "^1.6.15",
    "i18next": "^25.8.18",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.577.0",
    "next": "^15.0.0",
    "pdfjs-dist": "^5.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "react-window": "^1.8.10",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "streamsaver": "^2.0.6",
    "stripe": "^20.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "dotenv": "^16.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
