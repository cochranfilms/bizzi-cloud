# Copy to k6/.env.local and fill in secrets (k6/.env.local is gitignored).
# Load before k6:  set -a && source k6/.env.local && set +a
# Or use:         ./scripts/k6-with-env.sh run …

# Required for most authenticated scripts
BASE_URL=http://localhost:3000
# Paste a fresh Firebase ID token only (starts with eyJ; from DevTools → Network → /api/* → Authorization). Tokens expire ~1h.
# Must be from the same origin as BASE_URL (localhost token vs prod URL = 401).
BEARER_TOKEN='eyJ_REPLACE_ME'

# --- Production example (uncomment / adjust; k6/.env.local only — never commit secrets) ---
# BASE_URL=https://www.bizzicloud.io
# K6_ALLOW_PRODUCTION=1
# BEARER_TOKEN='eyJ_...'   # copy while logged into that exact prod site (same Firebase project as the API)
# For writes/uploads/etc. also: K6_ALLOW_MUTATIONS=1 and real TEST_* ids that exist in prod.

# Optional: scoped / gallery scripts
DRIVE_ID=
GALLERY_ID=
ORGANIZATION_ID=
TEAM_OWNER_ID=

# Production guard (substring match on BASE_URL — localhost is unaffected)
K6_PRODUCTION_URL_SUBSTRINGS=www.bizzicloud.io,bizzicloud.io
K6_ALLOW_PRODUCTION=0
