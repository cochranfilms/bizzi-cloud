rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /** Seat may use owner-linked team storage when active or cold_storage (matches Admin/API checks). */
    function personalTeamSeatAllowsOwnerStorage(teamOwnerUid) {
      return request.auth != null
        && teamOwnerUid is string
        && exists(/databases/$(database)/documents/personal_team_seats/$(teamOwnerUid + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/personal_team_seats/$(teamOwnerUid + '_' + request.auth.uid)).data.status in ['active', 'cold_storage'];
    }
    match /personal_team_settings/{ownerId} {
      allow read: if request.auth != null
        && (request.auth.uid == ownerId
          || personalTeamSeatAllowsOwnerStorage(ownerId));
      /** Writes go through /api/personal-team/settings (Admin SDK) only. */
      allow write: if false;
    }
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /linked_drives/{driveId} {
      function personalTeamCanReadOwnerDrive() {
        return resource.data.organization_id == null
          && resource.data.personal_team_owner_id == resource.data.userId
          && resource.data.userId is string
          && personalTeamSeatAllowsOwnerStorage(resource.data.userId);
      }
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.userId
          || (resource.data.organization_id is string
            && exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid)).data.role == 'admin')
          || personalTeamCanReadOwnerDrive());
      function orgLinkedDriveAdmin() {
        return resource.data.organization_id is string
          && exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid)).data.role == 'admin';
      }
      // Split write so team members can update owner drives (e.g. last_synced_at) but cannot delete them.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.userId
          || orgLinkedDriveAdmin()
          || personalTeamCanReadOwnerDrive());
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.userId
          || orgLinkedDriveAdmin());
    }
    match /backup_snapshots/{snapshotId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    match /backup_files/{fileId} {
      function backupPersonalTeamMemberRead() {
        return resource.data.organization_id == null
          && resource.data.personal_team_owner_id is string
          && personalTeamSeatAllowsOwnerStorage(resource.data.personal_team_owner_id);
      }
      /** Seat member can read any file on a team-container drive (uploader may be owner; file row may omit personal_team_owner_id). */
      function backupFileOnTeamDriveSeatRead() {
        return resource.data.organization_id == null
          && resource.data.linked_drive_id is string
          && exists(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id))
          && get(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id)).data.personal_team_owner_id
              == get(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id)).data.userId
          && get(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id)).data.personal_team_owner_id is string
          && personalTeamSeatAllowsOwnerStorage(get(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id)).data.personal_team_owner_id);
      }
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || (exists(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id))
            && get(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id)).data.userId == request.auth.uid)
          || (resource.data.organization_id is string
            && exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid)).data.role == 'admin')
          || backupPersonalTeamMemberRead()
          || backupFileOnTeamDriveSeatRead());
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && (request.resource.data.personal_team_owner_id == null
          || (request.resource.data.personal_team_owner_id is string
            && personalTeamSeatAllowsOwnerStorage(request.resource.data.personal_team_owner_id)));
      allow update, delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
          || (exists(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id))
            && get(/databases/$(database)/documents/linked_drives/$(resource.data.linked_drive_id)).data.userId == request.auth.uid)
          || (resource.data.organization_id is string
            && exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid)).data.role == 'admin'));
    }
    match /personal_team_seats/{seatId} {
      allow read: if request.auth != null
        && (resource.data.member_user_id == request.auth.uid
          || resource.data.team_owner_user_id == request.auth.uid);
      allow write: if false;
    }
    match /personal_team_invites/{inviteId} {
      allow read, write: if false;
    }
    match /pinned_items/{itemId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    match /local_store_entries/{entryId} {
      allow read, write: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
    }
    match /devices/{deviceId} {
      allow read, write: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
    }
    match /folder_shares/{shareId} {
      allow create: if request.auth != null && request.resource.data.owner_id == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.owner_id == request.auth.uid;
    }
    match /transfers/{slug} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read: if true;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    match /organizations/{orgId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/organization_seats/$(orgId + '_' + request.auth.uid));
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/organization_seats/$(orgId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/organization_seats/$(orgId + '_' + request.auth.uid)).data.role == 'admin';
    }
    match /organization_seats/{seatId} {
      allow read: if request.auth != null
        && (resource.data.user_id == request.auth.uid
          || (exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid)).data.role == 'admin'));
      allow create: if request.auth != null
        && request.resource.data.organization_id is string
        && exists(/databases/$(database)/documents/organizations/$(request.resource.data.organization_id))
        && (request.resource.data.user_id == request.auth.uid
          && get(/databases/$(database)/documents/organizations/$(request.resource.data.organization_id)).data.created_by == request.auth.uid
          || exists(/databases/$(database)/documents/organization_seats/$(request.resource.data.organization_id + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/organization_seats/$(request.resource.data.organization_id + '_' + request.auth.uid)).data.role == 'admin');
      allow update, delete: if request.auth != null
        && (resource.data.user_id == request.auth.uid
          || (exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid)).data.role == 'admin'));
    }
    match /cold_storage_files/{doc} {
      allow read, write: if false;
    }
    match /stripe_prices/{doc} {
      allow read, write: if false;
    }
    match /enterprise_contacts/{doc} {
      allow read, write: if false;
    }
    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.recipientUserId == request.auth.uid;
      allow write: if false;
    }
    match /file_comments/{commentId} {
      allow read, write: if false;
    }
    match /file_hearts/{heartId} {
      allow read, write: if false;
    }
    match /file_share_recipients/{recId} {
      allow read, write: if false;
    }
    match /audit_logs/{docId} {
      allow read, write: if false;
    }
    match /activity_logs/{docId} {
      allow read: if request.auth != null
        && ((resource.data.actor_user_id == request.auth.uid
              && resource.data.scope_type == 'personal_account')
            || (resource.data.organization_id is string
                && resource.data.scope_type == 'organization'
                && exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid))));
      allow write: if false;
    }
    match /user_recent_opens/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    /** Quota holds for uploads; only Admin SDK / Cloud Functions may write. */
    match /storage_quota_reservations/{reservationId} {
      allow read, write: if false;
    }
    match /workspaces/{workspaceId} {
      allow read: if request.auth != null
        && resource.data.organization_id is string
        && exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid));
      allow create: if request.auth != null
        && request.resource.data.organization_id is string
        && exists(/databases/$(database)/documents/organization_seats/$(request.resource.data.organization_id + '_' + request.auth.uid));
      allow update, delete: if request.auth != null
        && resource.data.organization_id is string
        && (resource.data.created_by == request.auth.uid
          || (exists(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/organization_seats/$(resource.data.organization_id + '_' + request.auth.uid)).data.role == 'admin'));
    }
  }
}
