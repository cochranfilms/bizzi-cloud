{
  "name": "bizzi-cloud-desktop",
  "version": "0.2.1",
  "description": "Mount Bizzi Cloud as a local drive for NLE editing",
  "author": "Bizzi Byte",
  "repository": "https://github.com/cochranfilms/bizzi-cloud",
  "private": true,
  "main": "dist-electron/main.js",
  "build": {
    "publish": null,
    "appId": "cloud.bizzi.desktop",
    "productName": "Bizzi Cloud",
    "asarUnpack": ["dist-electron/preload.js"],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "resources/icon.icns",
      "target": ["dmg"],
      "identity": "-",
      "hardenedRuntime": true,
      "extendInfo": {
        "CFBundleName": "Bizzi Cloud"
      },
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      
      "extraFiles": [
        {"from": "PlugIns", "to": "PlugIns", "filter": ["**/*"]}
      ]
    },
    "directories": {
      "output": "release"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json && cp electron/mount/refresh-folder-script.js dist-electron/mount/",
    "electron:dev": "npm run build:electron && concurrently \"vite\" \"electron .\"",
    "electron": "vite build && npm run build:electron && electron .",
    "dist": "npm run build && node scripts/prepare-file-provider.js && node scripts/fix-native-deps.js && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-macos-file-provider": "^1.0.12",
    "electron-store": "^8.1.0",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "concurrently": "^9.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vite": "^5.0.0"
  }
}
