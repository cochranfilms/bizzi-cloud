{
  "name": "bizzi-cloud-desktop",
  "version": "0.1.1",
  "description": "Mount Bizzi Cloud as a local drive for NLE editing",
  "author": "Bizzi Byte",
  "repository": "https://github.com/cochranfilms/bizzi-cloud",
  "private": true,
  "main": "dist-electron/main.js",
  "build": {
    "publish": null,
    "appId": "cloud.bizzi.desktop",
    "productName": "Bizzi Cloud",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "resources/icon.icns",
      "target": ["dmg"],
      "extendInfo": {
        "CFBundleName": "Bizzi Cloud"
      }
    },
    "directories": {
      "output": "release"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "tsc -p tsconfig.electron.json && concurrently \"vite\" \"electron .\"",
    "electron": "vite build && tsc -p tsconfig.electron.json && electron .",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "concurrently": "^9.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vite": "^5.0.0"
  }
}
