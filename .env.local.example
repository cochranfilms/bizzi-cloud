# Firebase - required for auth and Firestore
# Get from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin - for API auth (verify tokens)
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire JSON as a single line or use JSON.stringify(parsed)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Backblaze B2 - for file storage (when set, sync uses B2 instead of Firebase Storage)
# B2 Console: Application Keys > Add a New Application Key
# Bucket: Bucket Settings > S3 Endpoint (e.g. https://s3.us-west-004.backblazeb2.com)
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET_NAME=bizzi-cloud
B2_ENDPOINT=
B2_REGION=us-west-004

# CDN (optional) - Route B2 downloads through Cloudflare for free egress (Bandwidth Alliance)
# When set, download URLs use cdn.yourdomain.com instead of presigned B2 URLs
# Requires: Cloudflare Worker deployed (see cloudflare-worker/README.md)
# CDN_BASE_URL=https://cdn.bizzicloud.io
# CDN_SECRET=  # Same as B2_SECRET_ACCESS_KEY, or a separate secret shared with the Worker

# App-level encryption (optional) - for sensitive metadata (API tokens, recovery codes, etc.)
# Generate: openssl rand -hex 32
# When set, use encryptField/decryptField for sensitive DB fields.
# APP_ENCRYPTION_KEY_CURRENT=
# APP_ENCRYPTION_KEY_PREVIOUS=  # For key rotation
# APP_ENCRYPTION_KEY_VERSION=1

# Client session - for email-gate access (invited clients without sign-up)
# Generate: openssl rand -hex 32
# Required for /client email verification when photographers invite clients
CLIENT_SESSION_SECRET=

# Stripe - for subscriptions and billing
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Webhook: Create endpoint in Stripe Dashboard pointing to /api/webhooks/stripe
# Required events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted, invoice.paid
# Local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe` for whsec_
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe Price IDs (optional) - if set, these override dynamic creation
# Products/Prices are created automatically on first checkout and cached in Firestore
# Base plans: STRIPE_PRICE_SOLO_MONTHLY, STRIPE_PRICE_SOLO_ANNUAL, etc.
# Addons: STRIPE_PRICE_GALLERY, STRIPE_PRICE_EDITOR, STRIPE_PRICE_FULLFRAME

# EmailJS - for enterprise invoice, sign-up link, and file share emails
# Dashboard: https://dashboard.emailjs.com
# Enable API requests: Account > Security
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID_INVOICE=
EMAILJS_TEMPLATE_ID_SIGNUP=
# Share notification email (when user shares files/folders with another user)
EMAILJS_TEMPLATE_ID_SHARE=
# Transfer notification email (when user creates transfer and enters client email)
EMAILJS_TEMPLATE_ID_TRANSFER=
# Subscription welcome email (when consumer purchases subscription on platform)
EMAILJS_TEMPLATE_ID_SUBSCRIPTION_WELCOME=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Base URL - use the canonical domain that does NOT redirect (avoids 307 webhook failures)
# If bizzicloud.io redirects to www, use www. If www redirects to apex, use apex.
# NEXT_PUBLIC_APP_URL=https://www.bizzicloud.io

# DEV ONLY: Skip Firebase Admin auth for B2 upload-url when testing without service account key
# Set to "true" ONLY in local .env.local. NEVER set in production.
# B2_SKIP_AUTH_FOR_TESTING=true

# BRAW proxy generation - path to ffmpeg-braw binary (Linux x86_64)
# Required for Blackmagic RAW (.braw) proxy creation. Run: node scripts/download-ffmpeg-braw.js
# FFMPEG_BRAW_PATH=/path/to/project/bin/ffmpeg-braw/ffmpeg
