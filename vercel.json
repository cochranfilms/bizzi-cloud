{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "functions": {
    "src/app/api/cron/proxy-generation/route.ts": {
      "memory": 512,
      "maxDuration": 120
    },
    "src/app/api/backup/generate-proxy/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/workers/standard-proxy/complete/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "src/app/api/workers/braw-proxy/complete/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/uploads/cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/mux-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/trash-cleanup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/deletion-jobs-worker",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/orphan-cleanup",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/org-removal-cleanup",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/cold-storage-cleanup",
      "schedule": "45 5 * * *"
    },
    {
      "path": "/api/cron/transfer-expiry-warnings",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/account-deletion-cleanup",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/grace-period-expiry",
      "schedule": "15 5 * * *"
    },
    {
      "path": "/api/cron/proxy-generation",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/migration-worker",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/migration-reconciliation",
      "schedule": "*/15 * * * *"
    }
  ]
}
